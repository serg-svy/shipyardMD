# ==============================================================
# DevForge — .env.example
# Copy this to .env and fill in your actual values
# NEVER commit .env — only .env.example goes to git
# ==============================================================

# ---- Application ----
APP_NAME=MyApp
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# ---- Database (PostgreSQL) ----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Mail ----
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=

# ---- File Storage (S3 / MinIO / Cloudflare R2) ----
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Search (Meilisearch) ----
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# ---- Push Notifications ----
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# ---- Payments ----
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ---- Auth / OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# ---- Monitoring ----
SENTRY_DSN=

# ---- SMS ----
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ---- AI ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- WebSockets (Reverb) ----
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
